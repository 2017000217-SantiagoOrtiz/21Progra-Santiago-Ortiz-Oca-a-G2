Algoritmo Act2_Casa
	Definir a Como Caracter
	Escribir "Escriba un caracter"
	Leer a
	Segun a Hacer
		"A","a","E","e","I","i","O","o","U","u":
			Escribir "Es una vocal"
		"1","2","3","4","4","5","6","7","8","9","10":
			Escribir "Es un digito"
		De Otro Modo:
			Escribir "No es vocal, ni es digito"
	FinSegun
	
FinAlgoritmo
