Algoritmo Ejercicio2
	Definir a,b,op Como Real
	Escribir "Digite su primer numero"
	leer a
	Escribir "Digite su segundo numero"
	leer b
	Escribir "Digite un numero del 1 al 4"
	Escribir "1 Suma"
	Escribir "2 Resta"
	Escribir "3 Mutiplicacion"
	Escribir "4 Division"
	leer op
	s=a+b
	r=a-b
	m=a*b
	d=a/b
	Segun op Hacer
		1: Escribir "Suma ",s
		2:Escribir"Resta ",r
		3:Escribir"Multiplicacion ",m
		4:Escribir"Division ",d
	FinSegun
	
FinAlgoritmo
