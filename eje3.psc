Algoritmo Ejercicio3
	definir l Como Caracter
	Escribir "Clasificacion de letras por rango"
	Escribir "Ingrese una letra de la A a la F"
	leer l
	Segun l Hacer
		"A" o "a":Escribir "Excelente"
		"B" o "b":Escribir "Bueno"
		"C" o "c":Escribir "Regular"
		"D" o "d":Escribir "Deficiente"
		"F" o "f":Escribir "Reprobado"
		De Otro Modo:
			Escribir "Digite otra letra validad de la A a la F"
	FinSegun
	
FinAlgoritmo
